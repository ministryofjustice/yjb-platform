  "bugs": {
    "url": "https://github.com/ministryofjustice/yjb-platform/issues"
  },
  "homepage": "https://github.com/ministryofjustice/yjb-platform#readme",
  "allowScripts": {
    "esbuild@0.28.0": true,
    "fsevents@2.3.3": true
  }
}
