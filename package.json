{
  "name": "yjb-platform",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "workspaces": [
    "apps/*",
    "e2e-tests"
  ],
  "scripts": {
    "build": "npm run build -w apps/frontend -w apps/api",
    "build:fe": "npm run build -w apps/frontend",
    "build:api": "npm run build -w apps/api",
    "lint": "npm run lint -w apps/frontend -w apps/api",
    "lint:fe": "npm run lint -w apps/frontend",
    "lint:api": "npm run lint -w apps/api",
    "start:dev": "npm run dev -w apps/frontend -w apps/api",
    "test": "npm run test -w apps/frontend -w apps/api",
    "test:ci": "npm run test:ci -w apps/frontend -w apps/api",
    "test:fe": "npm run test -w apps/frontend",
    "test:fe:no-logs": "npm run test:no-logs -w apps/frontend",
    "test:api": "npm run test -w apps/api",
    "test:e2e": "npm run test -w e2e-tests",
    "setup": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ministryofjustice/yjb-platform.git"
  },
  "keywords": [],
